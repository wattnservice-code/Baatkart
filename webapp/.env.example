# Stadia Maps – karttiles (dag og natt)
# Registrer gratis konto på https://stadiamaps.com og opprett en property.
# Legg til domenet ditt (f.eks. baatkart.vercel.app) i property-innstillingene.
# VITE_-prefiks gjør at nøkkelen inngår i klient-bundle (OK — Stadia-nøkler er publishable).
VITE_STADIA_KEY=din_stadia_api_nøkkel_her
